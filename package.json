{
  "name": "ng-jester",
  "version": "1.0.0",
  "description": "CLI tool that reads an Angular project and generates Jest boilerplate",
  "main": "dist/cli/index.js",
  "bin": {
    "ng-jester": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli/index.ts",
    "dev": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "figlet": "^1.11.0",
    "gradient-string": "^2.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
